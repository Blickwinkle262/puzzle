# Web external port
WEB_PORT=8080

# Cookie security:
# - true: must access site via HTTPS
# - false: allows plain HTTP (local/LAN testing)
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax

# Session TTL in days
SESSION_TTL_DAYS=30
PUBLIC_REGISTRATION_ENABLED=true
ADMIN_USERNAME_FALLBACK_ENABLED=true
# 可选：如果配置了 ADMIN_BOOTSTRAP_TOKEN，注册保留管理员用户名时必须提供 admin_bootstrap_token
# ADMIN_BOOTSTRAP_TOKEN=
# 密码策略：注册/改密/重置必须满足“至少 6 位”
TRUST_PROXY=false

# Generated story assets root inside backend/worker containers
STORY_CONTENT_ROOT=/app/backend/data/generated/content/stories
STORY_GENERATOR_OUTPUT_ROOT=/app/backend/data/generated/content/stories
STORY_GENERATOR_INDEX_FILE=/app/backend/data/generated/content/stories/index.json
STORY_GENERATOR_LOG_DIR=/app/backend/data/generated/logs/story_generator
STORY_GENERATOR_SUMMARY_DIR=/app/backend/data/generated/summaries/story_generator

# Admin usernames for /api/admin/generate-story (comma separated)
ADMIN_USERNAMES=admin
MAX_GENERATION_JOBS=100
STORY_GENERATOR_WORKER_TOKEN=dev-worker-token

# Worker settings
AIHUBMIX_API_KEY=
STORY_GENERATOR_BACKEND_URL=http://backend:8787
STORY_GENERATOR_QUEUE_POLL_SECONDS=2
STORY_GENERATOR_BASE_URL=https://aihubmix.com/v1
STORY_GENERATOR_TEXT_MODEL=qwen3-next-80b-a3b-instruct
STORY_GENERATOR_SUMMARY_MODEL=qwen3-next-80b-a3b-instruct
STORY_GENERATOR_IMAGE_MODEL=doubao/doubao-seedream-4-5-251128
# 多 key 场景可在后端环境中补充，例如 AIHUBMIX_API_KEY_BACKUP

# Book ingest SQLite for admin chapter picker
BOOK_INGEST_DB_PATH=/app/book_ingest_data/books.sqlite
